# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next

class Solution:
    def reverseKGroup(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        if not head or k == 1:
            return head
        
        # Dummy node helps handle edge cases like reversing the head of the list
        dummy = ListNode(0)
        dummy.next = head
        
        # 'groupPrev' is the node right before the current k-group we want to reverse
        groupPrev = dummy
        
        while True:
            # 1. Check if there are at least k nodes left in the list
            kth = self.getKthNode(groupPrev, k)
            if not kth:
                break  # Less than k nodes left, leave them as they are
                
            # 'groupNext' is the node right after the current k-group
            groupNext = kth.next
            
            # 2. Reverse the current k-group
            # 'prev' starts at 'groupNext' because the first node of our reversed 
            # group needs to point to the remainder of the list.
            prev, curr = groupNext, groupPrev.next
            while curr != groupNext:
                tmp = curr.next
                curr.next = prev
                prev = curr
                curr = tmp
            
            # 3. Reconnect the reversed group back into the main list
            tmp = groupPrev.next  # This was the old head, now it's the tail of the reversed group
            groupPrev.next = kth  # Point the previous group's end to the new head of this group
            groupPrev = tmp       # Move 'groupPrev' to the tail of our newly reversed group
            
        return dummy.next

    def getKthNode(self, curr: Optional[ListNode], k: int) -> Optional[ListNode]:
        while curr and k > 0:
            curr = curr.next
            k -= 1
        return curr
