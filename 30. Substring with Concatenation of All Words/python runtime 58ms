from collections import Counter
from typing import List

class Solution:
    def findSubstring(self, s: str, words: List[str]) -> List[int]:
        # Edge case: if the string or words list is empty
        if not s or not words:
            return []
            
        word_len = len(words[0])
        word_count = len(words)
        total_len = word_len * word_count
        s_len = len(s)
        
        # Count the frequency of each word we need to match
        target_counts = Counter(words)
        result = []
        
        # There are 'word_len' possible shifts/offsets to start our sliding window
        for i in range(word_len):
            left = i
            right = i
            current_counts = Counter()
            words_matched = 0
            
            # Slide the window across the string by word blocks
            while right + word_len <= s_len:
                # Extract the word at the right end of the window
                word = s[right:right + word_len]
                right += word_len
                
                if word in target_counts:
                    current_counts[word] += 1
                    words_matched += 1
                    
                    # If we have more occurrences of 'word' than needed, 
                    # shrink the window from the left until it's valid again.
                    while current_counts[word] > target_counts[word]:
                        left_word = s[left:left + word_len]
                        current_counts[left_word] -= 1
                        words_matched -= 1
                        left += word_len
                        
                    # If the number of matched words equals total words, we found a valid index
                    if words_matched == word_count:
                        result.append(left)
                        
                else:
                    # The word is not in our list at all. Reset the window entirely.
                    current_counts.clear()
                    words_matched = 0
                    left = right
                    
        return result
