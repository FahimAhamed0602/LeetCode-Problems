class Solution:
    def generateParenthesis(self, n: int) -> List[str]:
        res = []
        
        def backtrack(current_str, open_count, close_count):
            # Base case: if the string is complete
            if len(current_str) == 2 * n:
                res.append(current_str)
                return
            
            # Rule 1: We can add an opening parenthesis if we haven't reached the limit 'n'
            if open_count < n:
                backtrack(current_str + "(", open_count + 1, close_count)
                
            # Rule 2: We can add a closing parenthesis if it matches a valid open one
            if close_count < open_count:
                backtrack(current_str + ")", open_count, close_count + 1)
                
        # Start the recursion with an empty string and 0 counts
        backtrack("", 0, 0)
        return res
