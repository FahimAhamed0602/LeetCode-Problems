class Solution:
    def fourSum(self, nums: list[int], target: int) -> list[list[int]]:
        nums.sort()
        results = []
        
        # A generalized recursive function to find N numbers that sum to 'target'
        def findNsum(l: int, r: int, target: int, N: int, current_result: list[int]):
            # Extreme Pruning: 
            # 1. Not enough numbers left
            # 2. Target is mathematically impossible with the remaining sorted numbers
            if r - l + 1 < N or N < 2 or target < nums[l] * N or target > nums[r] * N:  
                return  
            
            # Base Case: Two Pointers for 2Sum
            if N == 2: 
                while l < r:
                    s = nums[l] + nums[r]
                    if s == target:
                        results.append(current_result + [nums[l], nums[r]])
                        l += 1
                        # Skip duplicates
                        while l < r and nums[l] == nums[l - 1]:
                            l += 1
                    elif s < target:
                        l += 1
                    else:
                        r -= 1
            # Recursive Step: Reduce N-Sum to (N-1)-Sum
            else: 
                for i in range(l, r + 1):
                    # Skip duplicates to avoid redundant recursive calls
                    if i == l or (i > l and nums[i - 1] != nums[i]):
                        findNsum(i + 1, r, target - nums[i], N - 1, current_result + [nums[i]])

        # Start the recursion looking for 4 numbers
        findNsum(0, len(nums) - 1, target, 4, [])
        return results
