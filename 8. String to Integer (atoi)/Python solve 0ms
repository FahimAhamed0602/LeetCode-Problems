class Solution(object):
    def myAtoi(self, s):
        """
        :type s: str
        :rtype: int
        """
        INT_MAX = 2**31 - 1
        INT_MIN = -2**31
        
        i = 0
        n = len(s)
        
        # 1. Skip leading whitespaces
        while i < n and s[i] == ' ':
            i += 1
            
        # If we reached the end of the string, return 0
        if i == n:
            return 0
            
        # 2. Determine sign
        sign = 1
        if s[i] == '-':
            sign = -1
            i += 1
        elif s[i] == '+':
            i += 1
            
        # 3. Read the integer
        result = 0
        while i < n and s[i].isdigit():
            digit = int(s[i])
            
            # Python automatically handles arbitrarily large integers,
            # so we can build the number first and clamp it at the end.
            result = result * 10 + digit
            i += 1
            
        # Apply the sign
        result *= sign
        
        # 4. Rounding (Clamp to 32-bit signed integer range)
        if result < INT_MIN:
            return INT_MIN
        if result > INT_MAX:
            return INT_MAX
            
        return result
