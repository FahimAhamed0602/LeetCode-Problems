class Solution:
    def longestValidParentheses(self, s: str) -> int:
        # Initialize a stack with -1 to serve as a base for the first valid substring
        stack = [-1]
        max_length = 0
        
        for i, char in enumerate(s):
            if char == '(':
                # Push the index of the open parenthesis
                stack.append(i)
            else:
                # Pop the last element (matching '(' or the base boundary)
                stack.pop()
                
                if not stack:
                    # If the stack is empty, it means the current ')' is unmatched.
                    # We push its index to act as the new base boundary for future valid substrings.
                    stack.append(i)
                else:
                    # If the stack is not empty, calculate the length of the current valid substring
                    max_length = max(max_length, i - stack[-1])
                    
        return max_length
