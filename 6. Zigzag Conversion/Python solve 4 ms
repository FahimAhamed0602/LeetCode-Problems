class Solution:
    def convert(self, s: str, numRows: int) -> str:
        # 1. Added condition to exit early if rows exceed string length
        if numRows == 1 or numRows >= len(s):
            return s

        # 2. Use a list of strings instead of a list of lists
        rows = [''] * numRows
        i, d = 0, 1

        for char in s:
            rows[i] += char
            if i == 0:
                d = 1
            elif i == numRows - 1:
                d = -1
            i += d

        # 3. Join once at the end
        return ''.join(rows)
