class Solution(object):
    def longestPalindrome(self, s):
        # Base case: if the string is empty, a single character, 
        # or the entire string is already a palindrome.
        if len(s) <= 1 or s == s[::-1]:
            return s
        
        start = 0
        max_len = 1
        
        for i in range(1, len(s)):
            # We want to check if the substring ending at index `i` 
            # can form a palindrome longer than our current max_len.
            
            # Check for an odd-length palindrome (max_len + 2)
            odd_start = i - max_len - 1
            odd_slice = s[odd_start : i + 1]
            
            # Check for an even-length palindrome (max_len + 1)
            even_start = i - max_len
            even_slice = s[even_start : i + 1]
            
            # If we found a longer odd palindrome, update start and max_len
            if odd_start >= 0 and odd_slice == odd_slice[::-1]:
                start = odd_start
                max_len += 2
                
            # Otherwise, if we found a longer even palindrome, update
            elif even_start >= 0 and even_slice == even_slice[::-1]:
                start = even_start
                max_len += 1
                
        return s[start : start + max_len]
