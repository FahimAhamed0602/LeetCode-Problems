# Definition for singly-linked list.
# class ListNode(object):
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next

class Solution(object):
    def addTwoNumbers(self, l1, l2):
        """
        :type l1: Optional[ListNode]
        :type l2: Optional[ListNode]
        :rtype: Optional[ListNode]
        """
        dummy_head = ListNode(0)
        current = dummy_head
        carry = 0
        
        # Loop continues while there are nodes left in either list, or if there's a carry left over
        while l1 is not None or l2 is not None or carry != 0:
            # Extract values from the current nodes, defaulting to 0 if the list has ended
            val1 = l1.val if l1 is not None else 0
            val2 = l2.val if l2 is not None else 0
            
            # Calculate the total sum and the new carry
            total = val1 + val2 + carry
            carry = total // 10
            
            # Create a new node with the digit part of the total
            current.next = ListNode(total % 10)
            current = current.next
            
            # Advance the pointers for l1 and l2 if they exist
            if l1 is not None:
                l1 = l1.next
            if l2 is not None:
                l2 = l2.next
                
        return dummy_head.next
