class Solution:
    def combinationSum(self, candidates: List[int], target: int) -> List[List[int]]:
        res = []
        
        def backtrack(i, cur, total):
            # Base Case 1: Successfully found a combination that matches the target
            if total == target:
                res.append(cur.copy())
                return
            
            # Base Case 2: Exceeded target or ran out of candidates
            if total > target or i >= len(candidates):
                return
            
            # Decision 1: Include candidates[i]
            cur.append(candidates[i])
            backtrack(i, cur, total + candidates[i])
            
            # Backtrack step: clean up the last added element before making the next decision
            cur.pop()
            
            # Decision 2: Exclude candidates[i] and move to the next candidate
            backtrack(i + 1, cur, total)
            
        backtrack(0, [], 0)
        return res
