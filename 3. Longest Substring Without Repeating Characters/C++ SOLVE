#include <string>
#include <vector>
#include <algorithm>

class Solution {
public:
    int lengthOfLongestSubstring(std::string s) {
        // Use an array to store the last seen index of characters
        // Initializing with -1 to indicate the character hasn't been seen
        int last_seen[128];
        for (int i = 0; i < 128; i++) last_seen[i] = -1;
        
        int max_len = 0;
        int left = 0;
        int n = s.length();
        
        for (int right = 0; right < n; right++) {
            char current_char = s[right];
            
            // If the character was seen before AND is inside the current window
            if (last_seen[current_char] >= left) {
                // Jump the left pointer to the right of the previous occurrence
                left = last_seen[current_char] + 1;
            }
            
            // Record the current character's index
            last_seen[current_char] = right;
            
            // Update max length
            max_len = std::max(max_len, right - left + 1);
        }
        
        return max_len;
    }
};
